							"attrs": {
								"dir": "auto"
							},
							"content": [
								{
									"type": "text",
									"text": "What if code fails midway cause of TLE or MLE or RE, worker constantly observes the  terminal and when it encounters a sigterm or sigsegv etc. kills the container and writes the result based on the error."
								}
							]
						},
						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							},
							"content": [
								{
									"type": "text",
									"text": "prlimit --as={insert mem limit} --cpu={time limit} ./my_program"
								}
							]
						},
						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							},
							"content": [
								{
									"type": "text",
									"text": "The above command can be used with dynamic values. "
								}
							]
						},
						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							},
							"content": [
								{
									"type": "text",
									"text": "Or i can use some scripting to run the codes in a more restrained and cleaner manner."
								}
							]
						}
					]
				}
			},
